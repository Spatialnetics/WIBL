{
    "useTabs": false,
    "tabWidth": 4,
    "printWidth": 120,
    "overrides": [
        {
            "files": "*.css",
            "options": {
                "tabWidth": 4
            }
        },
        {
            "files": ["*.html", "*.js"],
            "options": {
                "tabWidth": 4
            }
        },
        {
            "files": "*.py",
            "options": {
                "tabWidth": 4
            }
        }
    ]
}
